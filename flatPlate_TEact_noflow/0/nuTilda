FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      nuTilda;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

val             .14;

internalField   uniform $val;

boundaryField
{
    left
    {
        type            freestream;
        freestreamValue uniform $val;
    }

    right
    {
        type            freestream;
        freestreamValue uniform $val;
    }

    cylinder
    {
        type            fixedValue;
        value           uniform 0;
    }

    slot
    {
        type            slip;
    }

    down
    {
        type            symmetryPlane;
    }

    up
    {
        type            symmetryPlane;
    }
}

