        type patch;
        faces
        (
            ( 0 3 4 7 )
        );
    }
    right
    {
        type patch;
        faces
        (
            ( 1 2 6 5 )
        );
    }
    up
    {
        type patch;
        faces
        (
            ( 2 3 7 6 )
        );
    }
    down
    {
        type patch;
        faces
        (
            ( 0 1 5 4 )
        );
    }
