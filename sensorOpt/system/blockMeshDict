FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

scale           1;

bU             20;
bD            -20;
bL            -20;
bR             50;

bk             -.5;
fr              .5;




vertices
(
    ($bL $bD $bk) // 0
    ($bL $bD $fr) // 1
    ($bL $bU $bk) // 2
    ($bL $bU $fr) // 3
    ($bR $bD $bk) // 4
    ($bR $bD $fr) // 5
    ($bR $bU $bk) // 6
    ($bR $bU $fr) // 7
);

blocks
(
    hex (0 4 6 2 1 5 7 3) (400 200 1) simpleGrading (1 1 1)
);

edges
(
    arc 0 2 180.0 (0 0 -1)
    arc 1 3 180.0 (0 0 -1)
);

boundary
(
    down
    {
        type symmetryPlane;
        faces
        (
            (0 1 5 4)
        );
    }
    right
    {
        type patch;
        faces
        (
            (4 5 7 6)
        );
    }
    up
    {
        type symmetryPlane;
        faces
        (
            (2 3 7 6)
        );
    }
    left
    {
        type patch;
        faces
        (
            (0 1 3 2)
        );
    }
);

neighbourPatch
(
);

mergePatchPairs
(
);

