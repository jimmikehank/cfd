FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField uniform (20 0 0);

boundaryField
{
    down
    {
        type            symmetryPlane;
    }
    right
    {
        type            zeroGradient;
    }
    up
    {
        type            symmetryPlane;
    }
    left
    {
        type            uniformFixedValue;
        uniformValue    constant (20 0 0);
        value           uniform (20 0 0);
    }
    cylinder
    {
        type            noSlip;
    }
    slot
    {
        type            uniformFixedValue;
        uniformValue    constant (50 0 0);
        value           uniform (50 0 0;)
    }
    defaultFaces
    {
        type            empty;
    }
}


